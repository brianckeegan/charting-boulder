# Copy to .env.local for `vercel dev`, and add the same keys in the Vercel
# dashboard (Project → Settings → Environment Variables) for production.
# NEVER commit real keys. .env* is gitignored.

# Your Supabase project (already filled in for this newsroom).
SUPABASE_URL=https://iplcjxbazezpjdzdpjxx.supabase.co

# SECRET key — Supabase Dashboard → Project Settings → API keys → "secret"
# (an sb_secret_… value; the legacy service_role JWT also works). It bypasses
# Row Level Security, so it lives ONLY here and in Vercel's env vars — never in
# the browser, the widget, or git. Paste your real key after the = sign.
SUPABASE_SECRET_KEY=

# Any non-empty random string. Salts the one-way duplicate-detection hash so it
# cannot be reversed to an IP address. Set once and keep stable. Generate e.g.
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
DEDUPE_SALT=

# Optional. Restrict CORS to your site once the embed URL is known, e.g.
#   https://boulderreportinglab.org
# Leave unset (defaults to *) while previewing from multiple hosts.
# ALLOWED_ORIGIN=https://boulderreportinglab.org
