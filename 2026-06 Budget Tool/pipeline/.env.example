# Copy to .env.local for `vercel dev`, and set the same in Vercel → Settings →
# Environment Variables for production. NEVER commit real keys (.env.local is
# gitignored). Every defense below is optional and activates only when set.

# --- Required ----------------------------------------------------------------
SUPABASE_URL=https://iplcjxbazezpjdzdpjxx.supabase.co

# SECRET key — Supabase → Project Settings → API keys → "secret" (sb_secret_…).
# Bypasses Row Level Security, so it lives ONLY here and in Vercel — never in
# the browser, the widget, or git. Paste your real key after the = sign.
SUPABASE_SECRET_KEY=

# --- Recommended: lock CORS to your site -------------------------------------
# Comma-separated origin allowlist (or "*"). The function echoes a matching
# Origin back; everything else is refused at the browser.
ALLOWED_ORIGIN=https://boulderreportinglab.org

# --- Bot defense: Cloudflare Turnstile (recommended) -------------------------
# Create a widget at dash.cloudflare.com → Turnstile. The SECRET goes here; the
# SITE KEY goes in the embed (window.__BBW_TURNSTILE__, ?turnstile=…, or the
# BBW_TURNSTILE build arg). When set, /api/submit rejects any post without a
# valid token.
TURNSTILE_SECRET=

# --- Rate limiting: Upstash Redis (recommended) ------------------------------
# Create a free Upstash Redis DB and paste its REST URL + token. When set,
# /api/submit caps submissions per IP per window. Ephemeral — nothing about the
# IP is ever persisted; keys expire after the window.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=3600
