# Copy to .env.local for `vercel dev`, and set the same in Vercel → Settings →
# Environment Variables for production. NEVER commit real keys (.env.local is
# gitignored).

# --- Required ----------------------------------------------------------------
SUPABASE_URL=https://iplcjxbazezpjdzdpjxx.supabase.co

# SECRET key — Supabase → Project Settings → API keys → "secret" (sb_secret_…).
# Bypasses Row Level Security, so it lives ONLY here and in Vercel — never in the
# browser, the widget, or git. Required for /api/submit (writes).
SUPABASE_SECRET_KEY=

# --- Recommended: lock CORS to your site -------------------------------------
# Comma-separated origin allowlist (or "*"). The function echoes a matching
# Origin back; everything else is refused at the browser.
ALLOWED_ORIGIN=https://boulderreportinglab.org

# --- Optional: cached aggregate-read route -----------------------------------
# /api/aggregate only reads the public tally, so it can run with just the
# browser-safe PUBLISHABLE key (no secret) — handy if you deploy Vercel only to
# cache reads while writes stay direct to Supabase. Point the widget's reads at
# it with ?agg=https://your-pipeline.vercel.app/api/aggregate (or BBW_AGG at
# build time). If SUPABASE_SECRET_KEY is set, that is used instead.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_2jy9CF17cyHSMAnVYSpFcA_tRecRIoi
