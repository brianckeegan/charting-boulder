# Environment for the offline analysis export (export-responses.py). Copy to
# .env.local (gitignored) or just `export` these in your shell before running.
# NEVER commit real keys.

# The Supabase project URL.
SUPABASE_URL=https://iplcjxbazezpjdzdpjxx.supabase.co

# SECRET key — Supabase → Project Settings → API keys → "secret" (sb_secret_…).
# Bypasses Row Level Security so it can READ individual rows for analysis, so it
# lives ONLY on trusted machines — never in the browser, the widget, or git.
# (SUPABASE_SERVICE_ROLE_KEY / SUPABASE_SERVICE_KEY are accepted as aliases.)
SUPABASE_SECRET_KEY=
